{
  "name": "video-thumbnail-tool",
  "version": "1.0.0",
  "private": true,
  "description": "Trim, concat, remux video and generate thumbnails, contact sheets, sprite sheets and shot boundaries online with FFmpeg.",
  "license": "AGPL-3.0-or-later",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r --parallel run dev",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r --if-present run typecheck",
    "test": "vitest run --exclude '**/api.integration.test.ts'",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9",
    "@playwright/test": "^1.51.0"
  },
  "packageManager": "pnpm@10.33.3"
}
